/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model for a
 * financial management application. All data is considered private and can only
 * be accessed by the user who created it. There is no concept of public data or
 * shared access between users.
 *
 * Data Structure: The data is organized hierarchically. All user-specific
 * data, including customers, invoices, and transactions, is stored in
 * subcollections under that user's unique document at `/users/{userId}`. This
 * structure inherently links data to its owner.
 *
 * Key Security Decisions:
 * - Strict Authentication: All read and write operations require a user to be
 *   signed in. Anonymous access is completely disallowed.
 * - Data Privacy: Users can only access documents within their own data tree
 *   (i.e., paths starting with `/users/{their_own_uid}`).
 * - User Enumeration Disabled: Listing documents in the top-level `/users`
 *   collection is forbidden to prevent attackers from discovering user IDs.
 * - Path and Data Consistency: Rules enforce that the `userId` stored inside a
 *   document must match the `{userId}` from the document's path. This ensures
 *   relational integrity and prevents data from being misplaced or mis-owned.
 *
 * Denormalization for Authorization: The security model relies on path-based
 * authorization, which is a form of structural denormalization. By placing a
 * user's data in a subcollection under their own ID, we avoid costly and slow
 * `get()` calls to check for ownership. For example, a rule for
 * `/users/{userId}/invoices/{invoiceId}` simply checks that the authenticated
 * user's ID matches the `{userId}` in the path.
 *
 * Structural Segregation: The design uses separate subcollections for each
 * data type (`customers`, `invoices`, `transactions`) under the user's root
 * document. This cleanly separates data with identical ownership rules and
 * simplifies client-side queries and security logic.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions to ensure rules are readable and maintainable.

    /**
     * Checks if the current request is from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the requesting user's UID matches the provided userId.
     * This is the primary function for enforcing data ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks if a document exists AND the requesting user is the owner.
     * Used for safe state-changing operations like update and delete.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Controls access to a user's own profile document.
     * @path /users/{userId}
     * @allow A user (uid: 'user123') can (create) their own profile document at `/users/user123`.
     * @deny A user (uid: 'user456') cannot (get) another user's profile at `/users/user123`.
     * @principle Restricts access to a user's own data tree and prevents user enumeration.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Disallow listing of users for security.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Controls access to the customers created by a specific user.
       * @path /users/{userId}/customers/{customerId}
       * @allow A user (uid: 'user123') can (list) all customers at `/users/user123/customers`.
       * @deny A user (uid: 'user456') cannot (delete) a customer at `/users/user123/customers/cust987`.
       * @principle Enforces document ownership for all CRUD operations on a subcollection.
       */
      match /customers/{customerId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Controls access to the invoices created by a specific user.
       * @path /users/{userId}/invoices/{invoiceId}
       * @allow A user (uid: 'user123') can (create) a new invoice at `/users/user123/invoices/inv456`.
       * @deny A user (uid: 'user456') cannot (get) an invoice at `/users/user123/invoices/inv456`.
       * @principle Enforces document ownership and validates relational integrity between the document and its path.
       */
      match /invoices/{invoiceId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Controls access to the transactions recorded by a specific user.
       * @path /users/{userId}/transactions/{transactionId}
       * @allow A user (uid: 'user123') can (update) a transaction at `/users/user123/transactions/txn789`.
       * @deny A user (uid: 'user456') cannot (list) transactions at `/users/user123/transactions`.
       * @principle Enforces document ownership for all CRUD operations on a subcollection.
       */
      match /transactions/{transactionId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}