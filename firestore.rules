/**
 * Core Philosophy: This ruleset enforces a strict user-ownership security model. All data is
 * considered private and is only accessible by the user who created it. Access control is
 * determined by the user's authenticated UID.
 *
 * Data Structure: The database is hierarchically organized around users. All application
 * data, including customers, invoices, and transactions, is stored in subcollections
 * nested under a specific user's document path: /users/{userId}/...
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isCreatingOwnContent(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }

    function isUserIdImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    function isIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    // --------------------------------------------------------------------------------
    // Collection Rules
    // --------------------------------------------------------------------------------

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && isIdImmutable();
      allow delete: if isExistingOwner(userId);

      match /customers/{customerId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }
      
      match /income/{incomeId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }

      match /invoices/{invoiceId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }
      
      match /services/{serviceId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }
      
      match /companyProfiles/{profileId} {
          allow get: if isOwner(userId);
          allow list: if isOwner(userId);
          allow create: if isCreatingOwnContent(userId);
          allow update: if isExistingOwner(userId) && isUserIdImmutable();
          allow delete: if isExistingOwner(userId);
      }
      
       match /scriptTemplates/{templateId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }

      match /expenses/{expenseId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }
      
      match /collaborators/{collaboratorId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }
      
      match /projects/{projectId} {
        // Un colaborador puede ver y editar proyectos donde sea el responsable asignado
        // incluso si están en la subcolección de otro usuario (el superuser).
        allow get: if isOwner(userId) || (isSignedIn() && resource.data.collaboratorId == request.auth.uid);
        allow list: if isOwner(userId) || (isSignedIn() && request.auth.uid != null); 
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) || (isSignedIn() && resource.data.collaboratorId == request.auth.uid);
        allow delete: if isExistingOwner(userId);
      }

      match /settings/{settingsId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
