/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model. All data is considered private to the user who created it.
 * There are no public or shared collections. Access to any piece of data is granted if, and only if, the requesting user's
 * authenticated UID matches the user ID in the document's path.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    function isCreatingOwnContent(userId) {
      return isOwner(userId) && request.resource.data.userId == userId;
    }

    function isUserIdImmutable() {
      return request.resource.data.userId == resource.data.userId;
    }

    function isIdImmutable() {
      return request.resource.data.id == resource.data.id;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && isIdImmutable();
      allow delete: if isExistingOwner(userId);

      // Colecciones financieras: SOLO el dueño puede acceder
      match /customers/{customerId} {
        allow get, list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }

      match /collaborators/{collaboratorId} {
        allow get, list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }

      match /invoices/{invoiceId} {
        allow get, list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }

      match /income/{incomeId} {
        allow get, list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }

      match /expenses/{expenseId} {
        allow get, list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }
      
      match /services/{serviceId} {
        allow get, list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }

      match /settings/{docId} {
        allow read, write: if isOwner(userId);
      }

      match /companyProfiles/{profileId} {
        allow get, list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }
      
      match /projects/{projectId} {
        // Un colaborador puede ver y editar proyectos donde sea el responsable asignado
        allow get: if isOwner(userId) || (isSignedIn() && resource.data.collaboratorId == request.auth.uid);
        allow list: if isOwner(userId) || (isSignedIn() && request.auth.uid != null); 
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) || (isSignedIn() && resource.data.collaboratorId == request.auth.uid);
        allow delete: if isExistingOwner(userId);
      }

      match /scriptTemplates/{templateId} {
        allow get, list: if isOwner(userId);
        allow create: if isCreatingOwnContent(userId);
        allow update: if isExistingOwner(userId) && isUserIdImmutable();
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}
